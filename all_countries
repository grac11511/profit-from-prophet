#Function for transform one model type into extract form 
process_model_extracts <- function(prefix, user_type, signup_channel, platform, scenario = "Incl Marketing") {
  
  #Select relevant models 
  df <- All_F %>%
    select(ds, contains(prefix))
  
  #Get model names 
  col_names <- setdiff(names(df), "ds")
  
  #Transform raw forecasts into extract form
  extracts <- map(col_names, function(col_name) {
    region <- str_extract(col_name, paste0("(?<=", prefix, "_R3_)[A-Z]{2}"))
    
    df %>%
      select(ds, !!sym(col_name)) %>%
      mutate(
        Region = region,
        UserType = user_type,
        SignupChannel = signup_channel,
        Platform = platform,
        Scenario = scenario
      ) %>%
      rename(Signups = !!sym(col_name))
  })
  
  #Generate and assign names
  cleaned_names <- str_replace(col_names, paste0("^", prefix, "_R3_"), "")
  names(extracts) <- paste0(cleaned_names, "_EXT")
  list2env(extracts, envir = .GlobalEnv)
}

