#Function 
compile_actuals <- function(A_names){
  
  a_data <- list()
  
  for (actual in A_names) {
    actual_data <- get(actual)
    a_data[[actual]] <- actual_data$y
  }
  
  #Compile all actuals with date column
  All_A <- tibble::tibble(get(A_names[1])$ds,!!!a_data)
  
  #Rename date column
  All_A <- All_A %>% 
    rename(ds = `get(A_names[1])$ds`)
  
  return(All_A)
}

