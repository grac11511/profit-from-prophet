    model_data <- get(paste0(model, "_F"))
    tibble_data[[model]] <- model_data$yhat
  }
  
  #Compile table of forecasts from all models 
  All_F <- tibble::tibble(get(F_names[1])$ds,!!!tibble_data)
  
  #Format
  All_F <- All_F %>% 
    rename(ds = `get(F_names[1])$ds`)
  
  return(All_F)
}

