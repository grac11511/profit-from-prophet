#Start timer
F_start <- Sys.time()

#Forecast Function 
prophet_forecast <- function(name, actuals, regressors, holidays) {
  
  #Create model with specified parameters
  model <- prophet(changepoint.range = 1, 
                   holidays = holidays,
                   daily.seasonality = FALSE, 
                   weekly.seasonality = 4, 
                   yearly.seasonality = 9.5,
                   changepoint.prior.scale = 0.05,
                   seasonality.prior.scale = 10, 
                   holidays.prior.scale = 10
  )
  
  #Add regressors 
  model <- add_regressor(model, 'perMar')
  model <- add_regressor(model, 'Campaigns')
  
  #Merge regressors and actuals 
  train <- merge(regressors, actuals, by = "ds", all.x = TRUE)
  
  #Forecast 
  model <- fit.prophet(model, train)
  forecast <- predict(model, regressors)
  
  #Make negatives equal to 0 
  forecast <- forecast %>% mutate(yhat = if_else(yhat < 0, 0, yhat))
  
  #Assign to model name
  assign(name, model, envir = .GlobalEnv)
  assign(paste0(name, "_F"), forecast, envir = .GlobalEnv)
}

