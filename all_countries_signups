#Compile Weekly Marketing Spend Regessor
for (i in seq_along(country_SN_list)) {
  
  country_SN <- country_SN_list[i]
  country_FN <- country_FN_list[i]
  
  message("Running forecast for: ", country_SN)
  
  # Cleaning & Transformation: Regressors -----------------------------------
  
  ############ Timeframe
  
  #Regressor Table Name
  regressor_tblname <- paste0(country_SN, "_TSU_R")
  
  #Generate daily date timeframe for actuals period
  tsu_dates <- seq(from = as.Date(D_ActualStart, format = "%Y-%m-%d"),
                   to = as.Date(D_ForecastEnd, format = "%Y-%m-%d"),
                   by = "1 days")
  
  #Convert to tibble and rename column
  tsu_df <- as_tibble(tsu_dates) %>%
    rename(ds = value)
  
  #Assign to dynamically named object
  assign(regressor_tblname, tsu_df)
  
  #Get the regressor table by name
  regressor_tbl <- get(regressor_tblname)
  
  ############ Regressor: Weekly Marketing Spend (Actuals & Forecast) 
  
  CC_MS_AF_W <- MS_AF_W %>% 
    filter(Country == country_SN) %>% 
    select(ds,perMar)
  
  #Turn weekly marketing spend into daily 
  CC_MS_AF_W <- CC_MS_AF_W %>%
    complete(ds = full_seq(ds, 1)) %>% 
    fill(perMar) %>%
    mutate(perMar = perMar/7) %>% 
    filter(ds <= D_MS_AtoF)
  
  #Turn monthly data into daily data by dividing by number of days in a month
  CC_MS_F_M <- MS_F_M %>%
    filter(COUNTRY_NAME == country_FN) %>%
    complete(MONTH = full_seq(MONTH,1)) %>% 
    fill(perMar) %>%
    mutate(days_in_month = days_in_month(MONTH)) %>% 
    mutate(perMar = perMar/days_in_month) %>% 
    rename(ds = MONTH) %>% 
    select(ds,perMar)
  
  #Filter for the for the date the marketing spend data switches into budget
  CC_MS_F_M <- CC_MS_F_M %>% 
    filter(ds > D_MS_AtoF)
  
  #Bind actuals and forecast marketing spend
  CC_MS <- rbind(CC_MS_AF_W,CC_MS_F_M)
  
  CC_MS$perMar[is.na(CC_MS$perMar)] <- 0
  CC_MS$perMar[is.nan(CC_MS$perMar)] <- 0
  
  # Compiling ---------------------------------------------------------------
  
  #Merge in Marketing Spend to regressor table
  regressor_tbl_pms <- merge(regressor_tbl,CC_MS,by = "ds",all.x = TRUE)
  
  regressor_tbl_pms$perMar[is.na(regressor_tbl_pms$perMar)] <- 0
  regressor_tbl_pms$perMar[is.nan(regressor_tbl_pms$perMar)] <- 0
  
  # Save to list by country name
  #regressor_tbl_list[[country_SN]] <- regressor_tbl_pms
  
  # Append to combined table with country tag
  regressor_tbl_pms <- regressor_tbl_pms %>% 
    mutate(country = country_SN) 
  all_pms_tbl <- bind_rows(all_pms_tbl, regressor_tbl_pms)

}

