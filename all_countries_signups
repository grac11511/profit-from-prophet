    EDU_MAR_WEB      = quote(CUSTOMER_TYPE == "Edu" & SIGNUP_SOURCE == "marketing" & PLATFORM == "web"),
    B2C              = quote(CUSTOMER_TYPE == "B2C"),
    B2C_ORG_WEB      = quote(CUSTOMER_TYPE == "B2C" & SIGNUP_SOURCE == "organic" & PLATFORM == "web"),
    B2C_ORG_IOS      = quote(CUSTOMER_TYPE == "B2C" & SIGNUP_SOURCE == "organic" & PLATFORM == "iOS"),
    B2C_ORG_AND      = quote(CUSTOMER_TYPE == "B2C" & SIGNUP_SOURCE == "organic" & PLATFORM == "Android"),
    B2C_MAR_WEB      = quote(CUSTOMER_TYPE == "B2C" & SIGNUP_SOURCE == "marketing" & PLATFORM == "web"),
    B2B              = quote(CUSTOMER_TYPE == "B2B"),
    B2B_ORG_WEB      = quote(CUSTOMER_TYPE == "B2B" & SIGNUP_SOURCE == "organic" & PLATFORM == "web"),
    B2B_MAR_WEB      = quote(CUSTOMER_TYPE == "B2B" & SIGNUP_SOURCE == "marketing" & PLATFORM == "web")
  )
  
  # Loop through each filter rule and assign to dynamic variable
  for (suffix in names(filters)) {
    var_name <- paste0(country_SN, "_", suffix, "_A")
    filtered_df <- SU_Country %>% filter(eval(filters[[suffix]]))
    assign(var_name, filtered_df)
  }
  
  #Format and structure for each split of actuals 
  for (A_name in A_names) {
    df <- get(A_name) 
    
    df <- df %>%
      select(ds, y) %>%
      group_by(ds) %>%
      summarise(y = sum(y), .groups = "drop") 
    
    if (!(D_ActualStart %in% df$ds)) {
      new_row <- df[1, ]
      new_row[1, ] <- NA
      new_row$ds <- D_ActualStart
      df <- bind_rows(df, new_row)
    }
    
    if (!(D_MS_AtoF %in% df$ds)) {
      new_row <- df[1, ]
      new_row[1, ] <- NA
      new_row$ds <- D_MS_AtoF
      df <- bind_rows(df, new_row)
    }
    
    
    df <- df %>%
      arrange(ds) %>% 
      complete(ds = full_seq(ds, 1))
    assign(A_name, df)  
  }
  
  #Filter for actuals period for each split of actuals
  for (B_name in B_names) {
    df_A <- get(paste0(B_name, "_A"))  
    filtered_df <- df_A %>% 
      filter(ds <= D_ForecastStart - 1) %>% 
      complete(ds = full_seq(ds, 1))
    assign(B_name, filtered_df) 
  }
  
  # Cleaning & Transformation: Regressors -----------------------------------
  
  ############ Regressor: Public Holidays (Actuals & Forecast)
  
  holidays_tblname <- paste0(country_SN, "_Holidays")
  
  #Format date
  Holidays$ds <- as.Date(Holidays$ds, format = "%m/%d/%Y")
  
  #Filter out NAs 
  Holidays <- Holidays %>% 
    filter(!is.na(country)) 
  
  #Filter for Relevant Holidays
  Holidays_filtered <- Holidays %>%
    filter(country == !!country_SN)
  
  #Assign to a dynamic object
  assign(holidays_tblname, Holidays_filtered)
  
  ############ Timeframe
  
  #Regressor Table Name
  regressor_tblname <- paste0(country_SN, "_TSU_R")
  
  #Generate daily date timeframe for actuals period
  tsu_dates <- seq(from = as.Date(D_ActualStart, format = "%Y-%m-%d"),
                   to = as.Date(D_ForecastEnd, format = "%Y-%m-%d"),
                   by = "1 days")
  
  #Convert to tibble and rename column
  tsu_df <- as_tibble(tsu_dates) %>%
    rename(ds = value)
  
  #Assign to dynamically named object
  assign(regressor_tblname, tsu_df)
  
  ############ Regressor: Campaign Dates (Actuals & Forecast)
  
  #Format
  Campaigns$ds <- as.Date(Campaigns$ds, format="%m/%d/%y")
  Campaigns <- as_tibble(Campaigns)
  
  #Get the regressor table by name
  regressor_tbl <- get(regressor_tblname)
  
  #Merge Campaigns into the regressor table
  regressor_tbl <- regressor_tbl %>% 
    merge(Campaigns, by = "ds", all.x = TRUE)
  
  #Assign it back to the original variable name
  assign(regressor_tblname, regressor_tbl)
  
  #Make NAs 0 
  regressor_tbl$Campaigns[is.na(regressor_tbl$Campaigns)] <- 0
  
  #Check: Total Campaign Days
  C_CampaignDays <- sum(regressor_tbl$Campaigns, na.rm = TRUE)
  
  ############ Regressor: Weekly Marketing Spend (Actuals & Forecast) 
  
  CC_MS_AF_W <- MS_AF_W %>% 
    filter(Country == country_SN) %>% 
    select(ds,perMar)
  
  #Turn weekly marketing spend into daily 
  CC_MS_AF_W <- CC_MS_AF_W %>%
    complete(ds = full_seq(ds, 1)) %>% 
    fill(perMar) %>%
    mutate(perMar = perMar/7) %>% 
    filter(ds <= D_MS_AtoF)
  
  #Turn monthly data into daily data by dividing by number of days in a month
  CC_MS_F_M <- MS_F_M %>%
    filter(COUNTRY_NAME == country_FN) %>%
    complete(MONTH = full_seq(MONTH,1)) %>% 
    fill(perMar) %>%
    mutate(days_in_month = days_in_month(MONTH)) %>% 
    mutate(perMar = perMar/days_in_month) %>% 
    rename(ds = MONTH) %>% 
    select(ds,perMar)
  
  #Filter for the for the date the marketing spend data switches into budget
  CC_MS_F_M <- CC_MS_F_M %>% 
    filter(ds > D_MS_AtoF)
  
  #Bind actuals and forecast marketing spend
  CC_MS <- rbind(CC_MS_AF_W,CC_MS_F_M)
  
  CC_MS$perMar[is.na(CC_MS$perMar)] <- 0
  CC_MS$perMar[is.nan(CC_MS$perMar)] <- 0
  
  #Merge in Marketing Spend to regressor table
  regressor_tbl <- merge(regressor_tbl,CC_MS,by = "ds",all.x = TRUE)
  assign(regressor_tblname, regressor_tbl)
  
  regressor_tbl$perMar[is.na(regressor_tbl$perMar)] <- 0
  regressor_tbl$perMar[is.nan(regressor_tbl$perMar)] <- 0
  
  ############ Regressor: Daily Marketing Spend (Actuals & Forecast) 
  
  #Filter for Country
  CC_MS_A_D <- MS_A_D %>% 
    filter(Country == country_SN) %>% 
    select(ds,perMar) %>%
    filter(ds < D_ForecastStart)
  
  #Bind actuals and forecast marketing spend
  CC_MS_D <- rbind(CC_MS_A_D,CC_MS_F_M)
  
  CC_MS_D$perMar[is.na(CC_MS_D$perMar)] <- 0
  CC_MS_D$perMar[is.nan(CC_MS_D$perMar)] <- 0
  
  #Rename
  CC_MS_D <- CC_MS_D %>% 
    rename(DperMar = perMar) 
  
  #Merge in Marketing Spend to regressor table
  regressor_tbl <- merge(regressor_tbl,CC_MS_D,by = "ds",all.x = TRUE)
  assign(regressor_tblname, regressor_tbl)
  
  regressor_tbl$DperMar[is.na(regressor_tbl$DperMar)] <- 0
  regressor_tbl$DperMar[is.nan(regressor_tbl$DperMar)] <- 0
  
  ############ Regressor: Class Days (Actuals & Forecast) 
  
  #Filter for Country
  ClassDays_filtered <- ClassDays %>% 
    select(ds, all_of(country_SN)) %>%
    rename(ClassDays = 2)
  
  #Format Date
  ClassDays_filtered$ds <- as.Date(ClassDays_filtered$ds, format = "%m/%d/%Y")
  
  #Format as tibble
  ClassDays_filtered <- as_tibble(ClassDays_filtered)
  
  #Merge in School Holidays to regressor table
  regressor_tbl <- merge(regressor_tbl,ClassDays_filtered,by = "ds",all.x = TRUE)
  
  # Manual Adjustments ------------------------------------------------------
  
  # Forecasting -------------------------------------------------------------
  
  #Forecast each model
  #for (i in seq_along(M_names)) {
  #  prophet_forecast_country_dms(M_names[i], get(B_names[i]), regressor_tbl, Holidays_filtered)
  #}
  
  for (i in seq_along(M_names)) {
    do.call(forecast_func, list(
      name = M_names[i],
      actuals = get(B_names[i]),
      regressors = regressor_tbl,
      holidays = Holidays_filtered
    ))
  }
  
  #Plot forecast figures and regression components
  for (i in seq_along(M_names)) {
    model <- get(M_names[i])
    forecast <- get(F_names[i])
    
    #Plot forecast
    print(plot(model, forecast) +
            ggtitle(paste("Forecast for", M_names[i])) +
            xlab("Year") +
            ylab("Sign Ups")
    )
    
    #Plot components
    #prophet_plot_components(model, forecast)
  }
  
  # Coefficients ------------------------------------------------------------
  
  #Retrieve coefficients for each model 
  for (dataset_name in M_names) {

    #Retrieve model coefficients
    current_dataset <- get(dataset_name)
    current_co <- current_dataset$params$beta %*% as.matrix(current_dataset$train.component.cols)
    
    #Format coefficients
    current_co <- transpose_df(as_tibble(current_co))
    current_co <- current_co %>% 
      rename(Regressor = rowname) %>%
      rename(!!paste0(dataset_name) := `1`)  
    
    #Collate into table
    current_co <- rbind(current_co, list('Intercept', current_dataset$params$m))
    assign(paste0(dataset_name, "_Co"), current_co)
  }

}

