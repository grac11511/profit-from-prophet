  mutate(Platform = "web") %>%
  mutate(Scenario = "Incl Marketing") %>%
  rename(Signups = M26_R3_US_B2B_MAR_WEB) 

#Format each extract 
for (name in EXT_labels) {
  df <- get(name) %>%
    rename(Date = ds) %>%
    select(Date, Region, UserType, Platform, SignupChannel, Signups, Scenario) %>%
    filter(Date >= D_ForecastStart)
  assign(name, df)  
}

#Format actuals 
Extract_A <- SU %>% 
  rename(Region = MAP_STRATEGY_REGION) %>% 
  rename(UserType = MAP_CUSTOMER_TYPE) %>% 
  rename(Platform = MAP_PLATFORM) %>% 
  rename(SignupChannel = MAP_SIGNUP_SOURCE) %>% 
  rename(Signups = SIGNUPS) %>% 
  select(Date, Region, UserType, Platform, SignupChannel, Signups) %>%
  filter(Date >= D_ActualStart) %>%
  filter(Date < D_ForecastStart) %>% 
  mutate(Scenario = "Incl Marketing") 

#Merge in forecasts with actuals
Extract_AF <- do.call("rbind", c(list(Extract_A), mget(EXT_labels)))

#Check: # of rows in Daily Extract 
C_DailyExtractRows <- nrow(Extract_AF)

#Transform from daily to end of month data 
Extract_AF <- Extract_AF %>%
  mutate(EOM = ceiling_date(Date, "month") - days(1)) %>% 
  group_by(EOM,Region,UserType,Platform,SignupChannel,Scenario) %>% 
  summarise(Signups = sum(Signups)) %>% 
  rename(Date = EOM) %>% 
  select(Date, Region, UserType, Platform, SignupChannel, Signups, Scenario)

#Checks: # of rows in Monthly Extract 
C_MonthlyExtractRows <- nrow(Extract_AF)

#Output as CSV
write.csv(Extract_AF, file = paste0(output_directory, as.character(Today_Text), "_", "Signups_Extract",".csv"), row.names = FALSE)

