# Coefficients ------------------------------------------------------------

#Start timer
Co_start <- Sys.time()

#Retrieve coefficients for each model 
for (dataset_name in M_names) {
  
  #Retrieve model coefficients
  current_dataset <- get(dataset_name)
  current_co <- current_dataset$params$beta %*% as.matrix(current_dataset$train.component.cols)
  
  #Format coefficients
  current_co <- transpose_df(as_tibble(current_co))
  current_co <- current_co %>% 
    rename(Regressor = rowname) %>%
    rename(!!paste0(dataset_name) := `1`)  
  
  #Collate into table
  current_co <- rbind(current_co, list('Intercept', current_dataset$params$m))
  assign(paste0(dataset_name, "_Co"), current_co)
}

