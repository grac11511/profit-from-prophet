#Compile Actuals
compile_actuals <- function(A_names){
  
  a_data <- list()
  
  for (actual in A_names) {
    
    actual_data <- get(actual)
    a_data[[actual]] <- actual_data$y
  }
  
  #Compile all actuals with date column
  All_A <- tibble::tibble(get(A_names[1])$ds,!!!a_data)
  
  #Rename date column
  All_A <- All_A %>% 
    rename(ds = `get(A_names[1])$ds`)
  
  return(All_A)
}

#Compile Forecasts
compile_forecasts <- function(M_names,F_names){
  
  #Initialize empty list to store data for forecasts
  tibble_data <- list()
  
  #Loop through each model and retrieve forecasts
  for (model in M_names) {
    model_data <- get(paste0(model, "_F"))
    tibble_data[[model]] <- model_data$yhat
  }
  
  #Compile table of forecasts from all models 
  All_F <- tibble::tibble(get(F_names[1])$ds,!!!tibble_data)
  
  #Format
  All_F <- All_F %>% 
    rename(ds = `get(F_names[1])$ds`)
  
  return(All_F)
}

#Compile Coefficients
compile_Co <- function(Co_names){
  
  #Initialize dataset with first model only 
  All_Co <- get(Co_names[1])
  
  #Merge and compile all model coefficients
  for (i in 2:length(Co_names)) {
    current_co <- get(Co_names[i])
    All_Co <- merge(All_Co, current_co, by="Regressor", all=TRUE)
  }
  
  #Reorder Regressors
  All_Co <- All_Co %>% 
    arrange(factor(Regressor, levels = c('Intercept','perMar','Campaigns',
                                         'additive_terms','multiplicative_terms','extra_regressors_additive','weekly','yearly')))
  return(All_Co)
  
}

#Compile Performance Metrics
compile_APE <- function(ape_names){
  
  #Initialize dataset with the first model
  All_APE <- get(ape_names[1])
  
  #Merge and compile metrics from all models
  for (ape_name in ape_names[-1]) {
    All_APE <- merge(All_APE, get(ape_name), by="Metric", all=TRUE)
  }
  
  #Reorder Metrics
  All_APE <- All_APE %>% 
    arrange(factor(Metric, levels = c('mape','mdape','smape','mae')))
  
  return(All_APE)
}

#Construct Extracts for MAU Model 
process_model_extracts <- function(prefix, user_type, platform, scenario = M_scenario) {
  
  #Select relevant models 
  df <- All_F %>%
    select(ds, contains(prefix))
  
  #Get model names 
  col_names <- setdiff(names(df), "ds")
  
  #Transform raw forecasts into extract form
  extracts <- map(col_names, function(col_name) {
    region <- str_extract(col_name, paste0("(?<=", prefix, "_)[A-Z]{2}"))
    
    df %>%
      select(ds, !!sym(col_name)) %>%
      mutate(
        Region = region,
        UserType = user_type,
        Platform = platform,
        Scenario = scenario
      ) %>%
      rename(MAU = !!sym(col_name))
  })
  
  #Generate and assign names
  cleaned_names <- str_replace(col_names, paste0("^", prefix, "_"), "")
  names(extracts) <- paste0(cleaned_names, "_EXT")
  list2env(extracts, envir = .GlobalEnv)
}

